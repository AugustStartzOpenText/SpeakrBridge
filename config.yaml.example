listener:
  host: 0.0.0.0
  port: 8080
  hmac_secret: "replace-with-speakr-webhook-secret"
  fallback_event: recording.transcription.completed

speakr:
  base_url: http://speakr-host:7000
  api_token: "replace-with-speakr-api-token"

ollama:
  host: http://192.168.1.50:11434
  model: llama3
  timeout_seconds: 90
  scoping_timeout_seconds: 180

onenote:
  notebook: "SC Team Notes"
  section: "Meeting Transcripts"
  manual_selection: false

scoping:
  enabled: true
  api_token: "replace-with-a-long-random-scoping-api-token"
  database_file: scoping_jobs.db
  output_directory: generated/scoping

notifications:
  enabled: true

logging:
  level: INFO
  file: speakrbridge.log
